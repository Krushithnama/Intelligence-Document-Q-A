# Copy to .env and fill values.

# Required
GEMINI_API_KEY=

# Gemini models (defaults are reasonable for Gemini)
GEMINI_CHAT_MODEL=gemini-2.0-flash
# Preferred embedding model (client will try fallbacks if unavailable).
GEMINI_EMBED_MODEL=gemini-embedding-001

# LLM provider (use Ollama to avoid API quotas)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Storage
# Use SQLite by default
DATABASE_URL=sqlite+aiosqlite:///../data/app.db

# Vector index locations
DOC_INDEX_DIR=../data/indexes/docs
MEMORY_INDEX_DIR=../data/indexes/memory
UPLOAD_DIR=../data/uploads

# Retrieval
TOP_K=8
RERANK_K=16
MAX_CONTEXT_CHARS=12000

# Memory
SHORT_TERM_TURNS=10
LONG_TERM_TOP_K=6

# Cache
ENABLE_CACHE=true
CACHE_TTL_SECONDS=900

# Optional: reduce Gemini API calls (useful on free/low quota keys)
# Set to 1 to disable long-term memory extraction (saves 1 LLM call per question)
DISABLE_LONG_TERM_EXTRACTION=1
# Set to 1 to disable session summary updates (saves 1 LLM call per question)
DISABLE_SESSION_SUMMARY=1
